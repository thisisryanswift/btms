{
  "extends": "../tsconfig.json",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "~/*": ["./src/*"],
      "~components/*": ["./src/components/*"],
      "~hooks/*": ["./src/hooks/*"],
      "~lib/*": ["./src/lib/*"],
      "~services/*": ["./src/services/*"],
      "~stores/*": ["./src/stores/*"],
      "~types/*": ["./src/types/*"]
    }
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.tsx",
    "entrypoints/**/*.ts",
    "entrypoints/**/*.tsx"
  ]
}