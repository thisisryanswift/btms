{
  "name": "btms",
  "displayName": "BTMS - Better Tab Management System",
  "version": "0.1.0",
  "description": "Better Tab Management System - AI-powered browser session management",
  "type": "module",
  "scripts": {
    "build": "wxt build",
    "build:firefox": "wxt build --browser firefox",
    "dev": "wxt .",
    "dev:firefox": "wxt . --browser firefox",
    "postinstall": "wxt prepare",
    "test": "vitest",
    "test:run": "vitest run",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.1",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitest/ui": "^4.0.16",
    "@wxt-dev/browser": "^0.1.32",
    "@wxt-dev/module-react": "^1.0.0",
    "autoprefixer": "^10.4.16",
    "jsdom": "^27.3.0",
    "postcss": "^8.4.32",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.3.3",
    "vitest": "^4.0.16",
    "wxt": "^0.20.13"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.15.0",
    "@tanstack/react-table": "^8.11.0",
    "@tanstack/react-virtual": "^3.0.0",
    "idb": "^8.0.3",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "zustand": "^4.4.7"
  }
}